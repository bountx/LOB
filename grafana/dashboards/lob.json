{
  "title": "LOB Ingest Pipeline",
  "uid": "lob-perf-01",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "tags": ["lob", "trading", "performance"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "links": [
    {
      "title": "Subscribers",
      "url": "/d/lob-sub-01",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "exchange",
        "label": "Exchange",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(lob_messages_total, exchange)",
        "refresh": 1,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "hide": 0,
        "options": [],
        "current": {}
      },
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(lob_messages_total{exchange=~\"$exchange\"}, symbol)",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "hide": 0,
        "options": [],
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Messages / sec",
      "description": "Total ingest rate across all symbols, with selected symbol overlaid for comparison",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lob_messages_total[1m]))",
          "legendFormat": "total msg/s",
          "refId": "A"
        },
        {
          "expr": "rate(lob_messages_total{exchange=~\"$exchange\",symbol=\"$symbol\"}[1m])",
          "legendFormat": "{{symbol}} msg/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Event Lag",
      "description": "Worst-case lag per exchange (exchange event timestamp vs local receive time)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by(exchange) (lob_event_lag_milliseconds)",
          "legendFormat": "{{exchange}} worst lag",
          "refId": "A"
        },
        {
          "expr": "lob_event_lag_milliseconds{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} {{symbol}} lag",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Update Processing Time",
      "description": "p50 / p95 / p99 and mean time to apply one order book update (histogram)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le, exchange, symbol) (rate(lob_processing_time_microseconds_bucket{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by(le, exchange, symbol) (rate(lob_processing_time_microseconds_bucket{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le, exchange, symbol) (rate(lob_processing_time_microseconds_bucket{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])))",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "expr": "rate(lob_processing_time_microseconds_sum{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m]) / rate(lob_processing_time_microseconds_count{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])",
          "legendFormat": "mean",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "BTC/USDT Price",
      "description": "Best ask and best bid from the order book",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_best_ask_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "Best Ask",
          "refId": "A"
        },
        {
          "expr": "lob_orderbook_best_bid_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "Best Bid",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Spread",
      "description": "Difference between best ask and best bid",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_spread_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "spread USD",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Order Book Depth",
      "description": "Number of price levels on each side of the book",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_asks_count{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "Asks",
          "refId": "A"
        },
        {
          "expr": "lob_orderbook_bids_count{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "Bids",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Process RAM (RSS)",
      "description": "Resident set size — physical memory pages currently mapped by the process",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_process_rss_bytes",
          "legendFormat": "RSS",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 8,
      "title": "Current Stats",
      "description": "Live snapshot of key ingest metrics",
      "type": "stat",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(lob_messages_total)",
          "legendFormat": "Total Messages",
          "refId": "A"
        },
        {
          "expr": "max by(exchange) (lob_event_lag_milliseconds)",
          "legendFormat": "Event Lag",
          "refId": "B"
        },
        {
          "expr": "rate(lob_processing_time_microseconds_sum{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m]) / rate(lob_processing_time_microseconds_count{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])",
          "legendFormat": "Avg Processing",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.99, sum by(le, exchange, symbol) (rate(lob_processing_time_microseconds_bucket{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])))",
          "legendFormat": "p99 Processing",
          "refId": "D"
        },
        {
          "expr": "lob_orderbook_best_ask_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "Best Ask",
          "refId": "E"
        },
        {
          "expr": "lob_orderbook_spread_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "Spread",
          "refId": "F"
        },
        {
          "expr": "lob_process_rss_bytes",
          "legendFormat": "RSS",
          "refId": "G"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Best Ask" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Spread" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }]
          },
          {
            "matcher": { "id": "byName", "options": "Event Lag" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 100 },
                { "color": "red", "value": 500 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Avg Processing" },
            "properties": [{ "id": "unit", "value": "µs" }]
          },
          {
            "matcher": { "id": "byName", "options": "p99 Processing" },
            "properties": [
              { "id": "unit", "value": "µs" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 500 },
                { "color": "red", "value": 2000 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RSS" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    }
  ]
}
