{
  "title": "LOB Performance",
  "uid": "lob-perf-01",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "tags": ["lob", "trading", "performance"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "links": [],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(lob_messages_total, symbol)",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "hide": 0,
        "options": [],
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Messages / sec",
      "description": "Total ingest rate across all symbols, with selected symbol overlaid for comparison",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(lob_messages_total[1m]))",
          "legendFormat": "total msg/s",
          "refId": "A"
        },
        {
          "expr": "rate(lob_messages_total{symbol=\"$symbol\"}[1m])",
          "legendFormat": "{{symbol}} msg/s",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Event Lag",
      "description": "Worst-case lag across all symbols, with selected symbol overlaid for comparison",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max(lob_event_lag_milliseconds)",
          "legendFormat": "worst lag ms (all)",
          "refId": "A"
        },
        {
          "expr": "lob_event_lag_milliseconds{symbol=\"$symbol\"}",
          "legendFormat": "{{symbol}} lag ms",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "Update Processing Time",
      "description": "Avg and worst-case processing time across all symbols, with selected symbol overlaid",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "avg(lob_processing_time_microseconds)",
          "legendFormat": "avg µs (all)",
          "refId": "A"
        },
        {
          "expr": "max(lob_max_processing_time_microseconds)",
          "legendFormat": "max µs (all)",
          "refId": "B"
        },
        {
          "expr": "lob_processing_time_microseconds{symbol=\"$symbol\"}",
          "legendFormat": "{{symbol}} µs",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "BTC/USDT Price",
      "description": "Best ask and best bid from the order book",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_best_ask_price{symbol=\"$symbol\"}",
          "legendFormat": "Best Ask",
          "refId": "A"
        },
        {
          "expr": "lob_orderbook_best_bid_price{symbol=\"$symbol\"}",
          "legendFormat": "Best Bid",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Spread",
      "description": "Difference between best ask and best bid",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_spread_price{symbol=\"$symbol\"}",
          "legendFormat": "spread USD",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "Order Book Depth",
      "description": "Number of price levels on each side of the book",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_asks_count{symbol=\"$symbol\"}",
          "legendFormat": "Asks",
          "refId": "A"
        },
        {
          "expr": "lob_orderbook_bids_count{symbol=\"$symbol\"}",
          "legendFormat": "Bids",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Current Stats",
      "description": "Live snapshot of key metrics",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(lob_messages_total)",
          "legendFormat": "Total Messages (all)",
          "refId": "A"
        },
        {
          "expr": "max(lob_event_lag_milliseconds)",
          "legendFormat": "Worst Lag (ms)",
          "refId": "B"
        },
        {
          "expr": "avg(lob_processing_time_microseconds)",
          "legendFormat": "Avg Processing (µs)",
          "refId": "C"
        },
        {
          "expr": "lob_orderbook_best_ask_price{symbol=\"$symbol\"}",
          "legendFormat": "Best Ask",
          "refId": "D"
        },
        {
          "expr": "lob_orderbook_best_bid_price{symbol=\"$symbol\"}",
          "legendFormat": "Best Bid",
          "refId": "E"
        },
        {
          "expr": "lob_orderbook_spread_price{symbol=\"$symbol\"}",
          "legendFormat": "Spread",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Best Ask" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Best Bid" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 2 }]
          },
          {
            "matcher": { "id": "byName", "options": "Spread" },
            "properties": [{ "id": "unit", "value": "currencyUSD" }, { "id": "decimals", "value": 4 }]
          },
          {
            "matcher": { "id": "byName", "options": "Event Lag (ms)" },
            "properties": [{ "id": "unit", "value": "ms" }]
          },
          {
            "matcher": { "id": "byName", "options": "Processing (µs)" },
            "properties": [{ "id": "unit", "value": "µs" }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    }
  ]
}
