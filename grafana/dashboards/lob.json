{
  "title": "LOB — Exchange Comparison",
  "uid": "lob-perf-01",
  "schemaVersion": 38,
  "version": 3,
  "refresh": "5s",
  "tags": ["lob", "trading", "performance"],
  "timezone": "browser",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "links": [
    {
      "title": "Exchange Detail",
      "url": "/d/lob-exch-01?var-exchange=${exchange}&var-symbol=${symbol}",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "Subscribers",
      "url": "/d/lob-sub-01",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    }
  ],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "exchange",
        "label": "Exchange",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(lob_messages_total, exchange)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1,
        "hide": 0,
        "options": [],
        "current": {}
      },
      {
        "name": "symbol",
        "label": "Symbol",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(lob_messages_total{exchange=~\"$exchange\"}, symbol)",
        "refresh": 1,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "hide": 0,
        "options": [],
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Messages / sec",
      "description": "Ingest rate per exchange (summed across all symbols)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(exchange) (rate(lob_messages_total{exchange=~\"$exchange\"}[1m]))",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Event Lag",
      "description": "Worst-case event lag per exchange (exchange timestamp vs local receive time)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "max by(exchange) (lob_event_lag_milliseconds{exchange=~\"$exchange\"})",
          "legendFormat": "{{exchange}} worst",
          "refId": "A"
        },
        {
          "expr": "lob_event_lag_milliseconds{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} $symbol",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 3,
      "title": "$symbol Price",
      "description": "Best ask and best bid per exchange — shows price convergence / divergence",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_best_ask_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} ask",
          "refId": "A"
        },
        {
          "expr": "lob_orderbook_best_bid_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} bid",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 4,
      "title": "$symbol Spread",
      "description": "Bid-ask spread per exchange — lower is tighter liquidity",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_spread_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 4,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 5,
      "title": "Processing Time p99",
      "description": "99th percentile order book update processing time per exchange",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by(le, exchange) (rate(lob_processing_time_microseconds_bucket{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])))",
          "legendFormat": "{{exchange}} p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by(le, exchange) (rate(lob_processing_time_microseconds_bucket{exchange=~\"$exchange\",symbol=\"$symbol\"}[2m])))",
          "legendFormat": "{{exchange}} p50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "µs",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 6,
      "title": "$symbol Order Book Depth",
      "description": "Number of price levels on each side of the book per exchange",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "lob_orderbook_asks_count{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} asks",
          "refId": "A"
        },
        {
          "expr": "lob_orderbook_bids_count{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} bids",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 7,
      "title": "Current Stats",
      "description": "Live snapshot — one value per exchange; RSS is process-wide",
      "type": "stat",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by(exchange) (lob_messages_total{exchange=~\"$exchange\"})",
          "legendFormat": "{{exchange}} messages",
          "refId": "A"
        },
        {
          "expr": "max by(exchange) (lob_event_lag_milliseconds{exchange=~\"$exchange\"})",
          "legendFormat": "{{exchange}} lag",
          "refId": "B"
        },
        {
          "expr": "lob_orderbook_spread_price{exchange=~\"$exchange\",symbol=\"$symbol\"}",
          "legendFormat": "{{exchange}} spread",
          "refId": "C"
        },
        {
          "expr": "lob_process_rss_bytes",
          "legendFormat": "RSS",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".* lag" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 100 },
                { "color": "red", "value": 500 }
              ]}}
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".* spread" },
            "properties": [
              { "id": "unit", "value": "currencyUSD" },
              { "id": "decimals", "value": 4 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RSS" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    }
  ]
}
